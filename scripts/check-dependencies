#!/bin/bash

echo "🔍 Verificando dependencias..."
echo ""

check_command() {
    local cmd="$1"
    local display="${2:-$1}"
    if command -v "$cmd" &>/dev/null; then
        local version=$("$cmd" --version 2>/dev/null | head -1 || echo "")
        echo -e "✅ $display \033[0;90m$version\033[0m"
    else
        echo "❌ $display — NO INSTALADO"
    fi
}

echo "=== Shells ==="
check_command zsh
check_command bash
check_command starship

echo ""
echo "=== Terminal ==="
check_command kitty

echo ""
echo "=== Editores ==="
check_command nvim "neovim"
check_command vim

echo ""
echo "=== Herramientas CLI ==="
check_command lsd
check_command batcat "bat (batcat)"
check_command fdfind "fd (fdfind)"
check_command rg "ripgrep"
check_command fzf
check_command zoxide
check_command yazi
check_command lazygit
check_command delta
check_command vivid
check_command fx
check_command dust
check_command procs
check_command tldr "tealdeer"
check_command btop
check_command fastfetch

echo ""
echo "=== Desarrollo ==="
check_command git
check_command node
check_command npm
check_command bun
check_command go
check_command rustc "rust"
check_command cargo
check_command python3
check_command pip3
check_command pipx

echo ""
echo "=== Utilidades ==="
check_command curl
check_command wget
check_command jq
check_command tree
check_command newsboat
check_command yt-dlp
check_command zathura

echo ""
echo "✅ Verificación completada"
