#!/bin/bash

set -e

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKUP_DIR="$HOME/dotfiles_backup_$(date +%Y%m%d_%H%M%S)"

echo "🚀 Instalando dotfiles..."

# Archivos y directorios que este script va a sobrescribir
ROOT_FILES=(
  .zshrc
  .bashrc
  .gitconfig
  .gitignore_global
  .zprofile
  .ripgreprc
)

CONFIG_ITEMS=(
  bat btop dunst fd kitty lazygit lsd nvim
  starship.toml yt-dlp zathura
)

# Backup selectivo — solo lo que vamos a tocar
NEEDS_BACKUP=false
for f in "${ROOT_FILES[@]}"; do
  [ -e "$HOME/$f" ] && NEEDS_BACKUP=true && break
done
for item in "${CONFIG_ITEMS[@]}"; do
  [ -e "$HOME/.config/$item" ] && NEEDS_BACKUP=true && break
done

if $NEEDS_BACKUP; then
  echo "📦 Creando backup selectivo en $BACKUP_DIR"
  mkdir -p "$BACKUP_DIR/.config"

  for f in "${ROOT_FILES[@]}"; do
    [ -e "$HOME/$f" ] && cp -r "$HOME/$f" "$BACKUP_DIR/$f" && echo "  backed up: ~/$f"
  done

  for item in "${CONFIG_ITEMS[@]}"; do
    [ -e "$HOME/.config/$item" ] && cp -r "$HOME/.config/$item" "$BACKUP_DIR/.config/$item" && echo "  backed up: ~/.config/$item"
  done
fi

# Symlinks de archivos raíz
echo ""
echo "🔗 Creando symlinks..."

for f in "${ROOT_FILES[@]}"; do
  ln -sf "$DOTFILES_DIR/$f" "$HOME/$f"
  echo "  → ~/$f"
done

# Symlinks de .config
mkdir -p "$HOME/.config"

for item in "${CONFIG_ITEMS[@]}"; do
  src="$DOTFILES_DIR/.config/$item"
  dst="$HOME/.config/$item"
  if [ -e "$src" ]; then
    ln -sf "$src" "$dst"
    echo "  → ~/.config/$item"
  fi
done

# Hacer scripts ejecutables
chmod +x "$DOTFILES_DIR/scripts"/*

echo ""
echo "✅ Dotfiles instalados correctamente"
echo "🔄 Reinicia tu terminal o ejecuta: source ~/.zshrc"
