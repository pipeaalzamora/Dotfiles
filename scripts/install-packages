#!/bin/bash

set -e

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "📦 Instalando paquetes esenciales para Arch Linux..."

# Actualizar sistema
sudo pacman -Syu --noconfirm

# Herramientas base
sudo pacman -S --noconfirm --needed \
  base-devel git curl wget unzip btop fastfetch stow jq

# Shell y terminal
sudo pacman -S --noconfirm --needed \
  zsh kitty

# Herramientas CLI modernas
sudo pacman -S --noconfirm --needed \
  fzf lsd vivid bat fd ripgrep zoxide lazygit git-delta \
  bat-extras tealdeer dust procs

# Utilidades
sudo pacman -S --noconfirm --needed \
  tree xclip wl-clipboard p7zip unrar yazi newsboat

# Fuentes Nerd (disponibles en repos oficiales)
sudo pacman -S --noconfirm --needed \
  ttf-jetbrains-mono-nerd ttf-meslo-nerd

# Starship prompt
sudo pacman -S --noconfirm --needed starship

# yay (AUR helper) — instalar si no existe
if ! command -v yay &>/dev/null; then
  echo "📦 Instalando yay (AUR helper)..."
  sudo pacman -S --noconfirm --needed git base-devel
  git clone https://aur.archlinux.org/yay.git /tmp/yay
  (cd /tmp/yay && makepkg -si --noconfirm)
  rm -rf /tmp/yay
fi

# fx (JSON viewer) — desde AUR
if ! command -v fx &>/dev/null; then
  yay -S --noconfirm fx
fi

# Oh My Zsh (instalación no interactiva)
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

# Plugins de zsh
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
[ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ] && \
  git clone https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
[ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ] && \
  git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

# Actualizar caché de fuentes
fc-cache -fv

echo ""
echo "✅ Paquetes instalados correctamente"
echo "🔧 Cambia tu shell a zsh: chsh -s \$(which zsh)"
echo "🔄 Cierra sesión y vuelve a entrar para que tome efecto"
