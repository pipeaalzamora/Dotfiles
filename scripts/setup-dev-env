#!/bin/bash

set -e

echo "🛠️  Configurando entorno de desarrollo..."

# Node.js con NVM
if [ ! -d "$HOME/.nvm" ]; then
  echo "📦 Instalando NVM..."
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash
  export NVM_DIR="$HOME/.nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  nvm install --lts
  nvm use --lts
fi

# Bun
if ! command -v bun &>/dev/null; then
  echo "📦 Instalando Bun..."
  curl -fsSL https://bun.sh/install | bash
fi

# Go (disponible en repos oficiales de Arch)
if ! command -v go &>/dev/null; then
  echo "📦 Instalando Go..."
  sudo pacman -S --noconfirm --needed go
fi

# Rust
if ! command -v rustc &>/dev/null; then
  echo "📦 Instalando Rust..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  source "$HOME/.cargo/env"
fi

# Python tools (en Arch usar pipx para evitar conflictos con el sistema)
echo "📦 Instalando herramientas de Python..."
sudo pacman -S --noconfirm --needed python python-pip pipx
pipx install poetry
pipx install black
pipx install flake8
pipx install pylint
# pipenv sigue disponible vía pip
pip install --user pipenv

echo ""
echo "✅ Entorno de desarrollo configurado"
